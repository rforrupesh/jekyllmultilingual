---
layout: none
permalink: /search.json
---
[
  {% comment %} ── POSTS ── {% endcomment %}
  {% for post in site.posts %}
  {
    "title"  : {{ post.title | jsonify }},
    "url"    : {{ post.url | prepend: site.baseurl | jsonify }},
    "lang"   : {{ post.lang | default: "en" | jsonify }},
    "type"   : "post",
    "excerpt": {{ post.excerpt | strip_html | normalize_whitespace | truncatewords: 30 | jsonify }}
  },
  {% endfor %}

  {% comment %} ── PAGES (about, contact, home, etc.) ── {% endcomment %}
  {% for page in site.pages %}
    {% if page.title and page.title != "" and page.name != "search.json" %}
  {
    "title"  : {{ page.title | jsonify }},
    "url"    : {{ page.url | prepend: site.baseurl | jsonify }},
    "lang"   : {{ page.lang | default: "en" | jsonify }},
    "type"   : "page",
    "excerpt": {{ page.content | strip_html | normalize_whitespace | truncatewords: 30 | jsonify }}
  },
    {% endif %}
  {% endfor %}

  {% comment %} ── COLLECTIONS (en/, fr/, es/ folders etc.) ── {% endcomment %}
  {% for collection in site.collections %}
    {% unless collection.label == "posts" %}
      {% for doc in collection.docs %}
        {% if doc.title and doc.title != "" %}
  {
    "title"  : {{ doc.title | jsonify }},
    "url"    : {{ doc.url | prepend: site.baseurl | jsonify }},
    "lang"   : {{ doc.lang | default: collection.label | jsonify }},
    "type"   : {{ collection.label | jsonify }},
    "excerpt": {{ doc.content | strip_html | normalize_whitespace | truncatewords: 30 | jsonify }}
  },
        {% endif %}
      {% endfor %}
    {% endunless %}
  {% endfor %}

  {% comment %} Dummy last entry so trailing commas above never break JSON {% endcomment %}
  { "title": "", "url": "", "lang": "", "type": "", "excerpt": "" }
]
