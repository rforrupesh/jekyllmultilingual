# Force browser to check for new updates on every single HTML visit
/*.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Cache CSS and JS but revalidate in the background (Improves LCP)
/assets/css/*
  Cache-Control: public, max-age=0, must-revalidate
/assets/js/*
  Cache-Control: public, max-age=0, must-revalidate

# Cache images for 1 year (Since logos/icons rarely change)
/assets/images/*
  Cache-Control: public, max-age=31536000, immutable

# Cache fonts for 1 year (Critical for maintaining 100% LCP)
/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable

