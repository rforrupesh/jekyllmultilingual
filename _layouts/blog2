---
layout: default
---
{% assign t = site.data.translations[page.lang] %}
{% assign base = site.baseurl %}

<section class="blog-index">
  <div class="container">
    <h1>{{ t.blog.title }}</h1>
    <ul class="post-list">
      {% assign posts = site.posts | where: "lang", page.lang %}
      {% for post in posts %}
      <li class="post-card">
        <span class="post-date">{{ t.blog.posted_on }} {{ post.date | date: "%B %d, %Y" }}</span>
        <h2><a href="{{ base }}{{ post.url }}">{{ post.title }}</a></h2>
        <p>{{ post.excerpt | strip_html | truncatewords: 25 }}</p>
        <a class="read-more" href="{{ base }}{{ post.url }}">{{ t.blog.read_more }} →</a>
      </li>
      {% endfor %}
    </ul>
  </div>
</section>
