---
layout: default
---
{% assign t = site.data.translations[page.lang] %}
{% assign base = site.baseurl %}

<article class="post-single">
  <div class="container">
    <header class="post-header">
      <p class="post-date">{{ t.blog.posted_on }} {{ page.date | date: "%B %d, %Y" }}</p>
      <h1>{{ page.title }}</h1>
    </header>

    <div class="post-body">
      {{ content }}
    </div>

    <footer class="post-footer">
      <a href="{{ base }}/{% if page.lang == 'fr' %}fr/{% endif %}blog/">
        {{ t.blog.back }}
      </a>
    </footer>
  </div>
</article>
